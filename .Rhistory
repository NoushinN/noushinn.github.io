header_pages:
- about.md
file.exists("software-.md")
files <- list.files(pattern = "\\.(md|yml|yaml|html|R)$", recursive = TRUE)
hits <- lapply(files, function(f) {
lines <- readLines(f, warn = FALSE)
bad <- grep("software-", lines, value = TRUE)
if (length(bad) > 0) {
data.frame(file = f, line = grep("software-", lines), text = bad)
}
})
do.call(rbind, hits)
dir.create("_includes")
